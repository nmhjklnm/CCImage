#!/usr/bin/env bash
# CCImage — one script to configure, create, start, stop, check, and enter.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.env"
COMPOSE_BASE=(-f "${SCRIPT_DIR}/docker-compose.yml")
SERVICE="ccimage"
SHIM_IF="ccimage-shim"
PORT_DIR="/tmp/ccimage-ports"

# ─── Colors ──────────────────────────────────────────────────────────
RED='\033[31m'  GREEN='\033[32m'  YELLOW='\033[33m'  CYAN='\033[36m'  BOLD='\033[1m'  RESET='\033[0m'

info()  { printf "${CYAN}▸${RESET} %s\n" "$*"; }
ok()    { printf "${GREEN}✓${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}!${RESET} %s\n" "$*"; }
err()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }

# ─── Env helpers ─────────────────────────────────────────────────────
_load_env() {
  [[ -f "$ENV_FILE" ]] && set -a && source "$ENV_FILE" && set +a
}

_read_env() {
  local key="$1"
  [[ -f "$ENV_FILE" ]] && grep -m1 "^${key}=" "$ENV_FILE" 2>/dev/null | cut -d= -f2- || echo ""
}

_write_env() {
  local key="$1" value="$2"
  if [[ -f "$ENV_FILE" ]] && grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
  else
    echo "${key}=${value}" >> "$ENV_FILE"
  fi
}

# ─── Mode detection ─────────────────────────────────────────────────
_detect_mode() {
  # Docker Desktop (Mac/Win) → local mode (bridge network)
  # Native Linux Docker      → remote mode (macvlan)
  if docker info 2>/dev/null | grep -qi "docker desktop\|operating system:.*docker desktop\|platform.*desktop"; then
    echo "local"
  elif [[ "$(uname -s)" == "Darwin" ]] || [[ "$(uname -s)" == MINGW* ]] || [[ "$(uname -s)" == CYGWIN* ]]; then
    echo "local"
  else
    echo "remote"
  fi
}

_get_mode() {
  local mode
  mode=$(_read_env DEPLOY_MODE)
  echo "${mode:-$(_detect_mode)}"
}

_compose_files() {
  local mode
  mode=$(_get_mode)
  if [[ "$mode" == "local" ]]; then
    echo "${COMPOSE_BASE[@]}" -f "${SCRIPT_DIR}/docker-compose.local.yml"
  else
    echo "${COMPOSE_BASE[@]}" -f "${SCRIPT_DIR}/docker-compose.macvlan.yml"
  fi
}

_compose() {
  local files
  files=($(_compose_files))
  docker compose "${files[@]}" "$@"
}

# ─── Network auto-detect (remote/macvlan only) ───────────────────────
_detect_network() {
  local iface gw addr ip prefix a b c d bits net_addr subnet container_last container_ip

  iface=$(ip route show default 2>/dev/null | awk '/default/{print $5; exit}')
  gw=$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}')

  if [[ -z "$iface" || -z "$gw" ]]; then
    err "Cannot detect default network interface"
    return 1
  fi

  addr=$(ip -4 addr show "$iface" | awk '/inet /{print $2; exit}')
  ip="${addr%/*}"
  prefix="${addr#*/}"

  IFS=. read -r a b c d <<< "$ip"
  bits=$((0xFFFFFFFF << (32 - prefix) & 0xFFFFFFFF))
  net_addr="$(( a & (bits >> 24 & 0xFF) )).$(( b & (bits >> 16 & 0xFF) )).$(( c & (bits >> 8 & 0xFF) )).$(( d & (bits & 0xFF) ))"
  subnet="${net_addr}/${prefix}"

  container_last=$(( (d + 100) % 254 + 1 ))
  container_ip="${a}.${b}.${c}.${container_last}"

  shim_last=$(( container_last % 254 + 1 ))
  shim_ip="${a}.${b}.${c}.${shim_last}"

  _write_env HOST_INTERFACE "$iface"
  _write_env MACVLAN_SUBNET "$subnet"
  _write_env MACVLAN_GATEWAY "$gw"
  _write_env MACVLAN_IP "$container_ip"
  _write_env SHIM_IP "$shim_ip"

  printf "  Interface:  ${BOLD}%s${RESET}\n" "$iface"
  printf "  Host IP:    %s\n" "$ip"
  printf "  Gateway:    %s\n" "$gw"
  printf "  Container:  ${BOLD}%s${RESET}\n" "$container_ip"
}

# ─── Macvlan shim (remote only) ──────────────────────────────────────
_shim_up() {
  [[ "$(_get_mode)" != "remote" ]] && return 0
  _load_env
  local parent="${HOST_INTERFACE:-}" cip="${MACVLAN_IP:-}" sip="${SHIM_IP:-}"
  [[ -z "$parent" || -z "$cip" || -z "$sip" ]] && return 0
  ip link show "$SHIM_IF" &>/dev/null && return 0

  ip link add "$SHIM_IF" link "$parent" type macvlan mode bridge
  ip addr add "${sip}/32" dev "$SHIM_IF"
  ip link set "$SHIM_IF" up
  ip route add "${cip}/32" dev "$SHIM_IF" 2>/dev/null || true
}

_shim_down() {
  ip link show "$SHIM_IF" &>/dev/null && ip link del "$SHIM_IF" 2>/dev/null || true
}

# ─── Port forwarding ─────────────────────────────────────────────────
_port_forward() {
  local port="$1"
  local mode
  mode=$(_get_mode)

  mkdir -p "$PORT_DIR"
  local pidfile="${PORT_DIR}/${port}.pid"
  if [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
    warn "Port $port already forwarded (pid $(cat "$pidfile"))"
    return 0
  fi

  if [[ "$mode" == "remote" ]]; then
    # Remote/macvlan: socat on host, needs shim to reach container
    _load_env
    local cip="${MACVLAN_IP:-}"
    [[ -z "$cip" ]] && { err "MACVLAN_IP not set. Run ./ccimage setup first."; return 1; }
    _shim_up

    if ! command -v socat &>/dev/null; then
      err "socat not found. Install with: apt install socat"
      return 1
    fi

    socat TCP-LISTEN:"$port",fork,reuseaddr,bind=127.0.0.1 TCP:"${cip}":"$port" &
    local pid=$!
    echo "$pid" > "$pidfile"

    sleep 0.3
    if kill -0 "$pid" 2>/dev/null; then
      ok "localhost:${port} → ${cip}:${port} (pid $pid)"
    else
      err "Failed to start forwarder on port $port"
      rm -f "$pidfile"
      return 1
    fi
  else
    # Local/bridge: get container IP on docker bridge, forward via socat or python
    local cip
    cip=$(_compose exec -T "$SERVICE" hostname -I 2>/dev/null | awk '{print $1}')
    [[ -z "$cip" ]] && { err "Cannot determine container IP"; return 1; }

    # Try socat first, fall back to python
    if command -v socat &>/dev/null; then
      socat TCP-LISTEN:"$port",fork,reuseaddr,bind=127.0.0.1 TCP:"${cip}":"$port" &
    elif command -v python3 &>/dev/null; then
      python3 -c "
import socket, threading, sys
def fwd(src, dst):
    try:
        while d := src.recv(4096):
            dst.sendall(d)
    except: pass
    finally: src.close(); dst.close()
s = socket.socket(); s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
s.bind(('127.0.0.1', $port)); s.listen(8)
while True:
    c, _ = s.accept()
    r = socket.create_connection(('$cip', $port))
    threading.Thread(target=fwd, args=(c,r), daemon=True).start()
    threading.Thread(target=fwd, args=(r,c), daemon=True).start()
" &
    else
      err "Need socat or python3 on host for port forwarding"
      return 1
    fi
    local pid=$!
    echo "$pid" > "$pidfile"
    sleep 0.3
    if kill -0 "$pid" 2>/dev/null; then
      ok "localhost:${port} → ${cip}:${port} (pid $pid)"
    else
      err "Failed to start forwarder on port $port"
      rm -f "$pidfile"
      return 1
    fi
  fi
}

_port_stop() {
  local port="$1"
  local pidfile="${PORT_DIR}/${port}.pid"
  if [[ -f "$pidfile" ]]; then
    kill "$(cat "$pidfile")" 2>/dev/null || true
    rm -f "$pidfile"
    ok "Stopped forwarding port $port"
  else
    warn "Port $port is not being forwarded"
  fi
}

_port_list() {
  local mode
  mode=$(_get_mode)

  mkdir -p "$PORT_DIR"
  _load_env
  local cip="${MACVLAN_IP:-container}" found=0

  for pidfile in "$PORT_DIR"/*.pid; do
    [[ -f "$pidfile" ]] || continue
    local port pid
    port=$(basename "$pidfile" .pid)
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      printf "  ${GREEN}●${RESET} localhost:%-6s → %s:%s  (pid %s)\n" "$port" "$cip" "$port" "$pid"
      found=1
    else
      rm -f "$pidfile"
    fi
  done

  [[ "$found" -eq 0 ]] && info "No ports forwarded. Use: ./ccimage port <port>"
}

_port_stop_all() {
  mkdir -p "$PORT_DIR"
  for pidfile in "$PORT_DIR"/*.pid; do
    [[ -f "$pidfile" ]] || continue
    kill "$(cat "$pidfile")" 2>/dev/null || true
    rm -f "$pidfile"
  done
}

# ─── Commands ─────────────────────────────────────────────────────────

cmd_setup() {
  echo ""
  printf "${BOLD}CCImage Setup${RESET}\n"
  echo ""

  # Proxy
  local proxy
  proxy=$(_read_env PROXY_URI)
  if [[ -n "$proxy" ]]; then
    info "Current proxy: ${BOLD}${proxy}${RESET}"
    read -rp "  New proxy URI (Enter to keep): " input
    [[ -n "$input" ]] && proxy="$input"
  else
    read -rp "  Proxy URI (e.g. ss://..., ip:port:user:pass): " proxy
  fi
  if [[ -z "$proxy" ]]; then
    err "Proxy is required"
    return 1
  fi
  [[ -n "$proxy" ]] && _write_env PROXY_URI "$proxy"

  # Auto-detect mode
  local mode
  mode=$(_detect_mode)
  _write_env DEPLOY_MODE "$mode"

  echo ""
  if [[ "$mode" == "local" ]]; then
    info "Detected: ${BOLD}local laptop${RESET} (Docker Desktop)"
    info "Mode: bridge network — container isolated"
  else
    info "Detected: ${BOLD}remote server${RESET} (native Linux Docker)"
    info "Mode: macvlan — container isolated from host"
    echo ""
    info "Detecting network..."
    _detect_network
  fi

  echo ""
  ok "Config saved to .env"
  echo ""
  info "Next: ${BOLD}./ccimage create${RESET}"
}

cmd_create() {
  [[ ! -f "$ENV_FILE" ]] && { warn "No .env found, running setup first..."; cmd_setup; }
  _load_env
  echo ""
  info "Pulling image..."
  docker pull ghcr.io/nmhjklnm/ccimage:latest
  echo ""
  ok "Image ready"
  info "Start with: ${BOLD}./ccimage start${RESET}"
}

cmd_start() {
  [[ ! -f "$ENV_FILE" ]] && { warn "No .env found, running setup first..."; cmd_setup; }
  _load_env
  info "Starting container..."
  _compose up -d
  _shim_up

  sleep 2

  local state
  state=$(_compose ps --format '{{.State}}' "$SERVICE" 2>/dev/null || echo "unknown")
  if [[ "$state" == "running" ]]; then
    ok "Container running"
    info "Enter with:   ${BOLD}./ccimage enter${RESET}"
    info "Check with:   ${BOLD}./ccimage check${RESET}"
    info "Forward port: ${BOLD}./ccimage port <port>${RESET}"
  else
    err "Container state: $state"
    info "Logs: ./ccimage logs"
  fi
}

cmd_stop() {
  _port_stop_all
  _shim_down
  info "Stopping container..."
  _compose down
  ok "Stopped"
}

cmd_restart() {
  cmd_stop
  cmd_start
}

cmd_enter() {
  exec _compose exec "$SERVICE" bash
}

cmd_check() {
  _compose exec "$SERVICE" ccimage-check
}

cmd_verify() {
  exec "${SCRIPT_DIR}/ccimage-verify"
}

cmd_port() {
  local subcmd="${1:-}"
  local port="${2:-}"

  case "$subcmd" in
    ""|ls|list)
      _port_list
      ;;
    stop)
      if [[ -z "$port" ]]; then
        _port_stop_all
        ok "All port forwarders stopped"
      else
        _port_stop "$port"
      fi
      ;;
    [0-9]*)
      _port_forward "$subcmd"
      ;;
    *)
      echo "Usage:"
      echo "  ./ccimage port <port>       Forward localhost:port to container"
      echo "  ./ccimage port list         List active forwarders"
      echo "  ./ccimage port stop [port]  Stop forwarder(s)"
      ;;
  esac
}

cmd_logs() {
  _compose logs --tail=50 -f "$SERVICE"
}

cmd_status() {
  _load_env
  echo ""
  printf "${BOLD}CCImage Status${RESET}\n"
  echo ""

  local mode
  mode=$(_get_mode)
  printf "  Mode:       %s\n" "$mode"

  local proxy
  proxy=$(_read_env PROXY_URI)
  if [[ -n "$proxy" ]]; then
    local display_proxy
    if [[ "$proxy" == *"://"* ]]; then
      display_proxy="${proxy%%://*}://***"
    else
      IFS=: read -r _h _p _rest <<< "$proxy"
      display_proxy="${_h}:${_p}:***"
    fi
    printf "  Proxy:      %s\n" "$display_proxy"
  else
    printf "  Proxy:      ${YELLOW}not configured${RESET}\n"
  fi

  if [[ "$mode" == "remote" ]]; then
    local cip
    cip=$(_read_env MACVLAN_IP)
    [[ -n "$cip" ]] && printf "  Container:  %s\n" "$cip"
  fi

  local state
  state=$(_compose ps --format '{{.State}}' "$SERVICE" 2>/dev/null || echo "not created")
  case "$state" in
    running) printf "  Status:     ${GREEN}running${RESET}\n" ;;
    *)       printf "  Status:     ${YELLOW}%s${RESET}\n" "$state" ;;
  esac

  local health
  health=$(_compose ps --format '{{.Health}}' "$SERVICE" 2>/dev/null || echo "")
  [[ -n "$health" ]] && printf "  Health:     %s\n" "$health"

  echo ""
  printf "${BOLD}Ports${RESET}\n"
  _port_list
  echo ""
}

cmd_destroy() {
  read -rp "Remove container and image? [y/N]: " confirm
  if [[ "$confirm" == [yY] ]]; then
    _port_stop_all
    _shim_down
    _compose down --rmi local --volumes 2>/dev/null || true
    ok "Removed"
  fi
}

cmd_help() {
  echo ""
  printf "${BOLD}Usage:${RESET} ./ccimage <command>\n"
  echo ""
  printf "${BOLD}Lifecycle:${RESET}\n"
  echo "  setup               Configure proxy (interactive)"
  echo "  create              Pull the Docker image"
  echo "  start               Start the container"
  echo "  stop                Stop the container"
  echo "  restart             Restart the container"
  echo "  destroy             Remove container and image"
  echo ""
  printf "${BOLD}Use:${RESET}\n"
  echo "  enter               Open a shell (run claude inside)"
  echo "  port <port>         Forward localhost:port to container"
  echo "  port list           List active port forwarders"
  echo "  port stop [port]    Stop port forwarder(s)"
  echo ""
  printf "${BOLD}Diagnostics:${RESET}\n"
  echo "  check               Network check (inside container)"
  echo "  verify              Verify outbound isolation (from host)"
  echo "  status              Show config, state, and ports"
  echo "  logs                Follow container logs"
  echo ""
}

# ─── Main ─────────────────────────────────────────────────────────────
cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  setup)    cmd_setup "$@" ;;
  create)   cmd_create "$@" ;;
  start)    cmd_start "$@" ;;
  stop)     cmd_stop "$@" ;;
  restart)  cmd_restart "$@" ;;
  enter)    cmd_enter "$@" ;;
  check)    cmd_check "$@" ;;
  verify)   cmd_verify "$@" ;;
  port)     cmd_port "$@" ;;
  status)   cmd_status "$@" ;;
  logs)     cmd_logs "$@" ;;
  destroy)  cmd_destroy "$@" ;;
  help|-h|--help) cmd_help ;;
  "")
    if [[ ! -f "$ENV_FILE" ]]; then
      cmd_setup
    else
      cmd_status
      cmd_help
    fi
    ;;
  *)
    err "Unknown command: $cmd"
    cmd_help
    exit 1
    ;;
esac
